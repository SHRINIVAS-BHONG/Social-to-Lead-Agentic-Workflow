# LLM Configuration
HUGGINGFACE_API_KEY=hf_your_token_here
LLM_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
LLM_TEMPERATURE=0.5

# RAG Configuration
RAG_TOP_K=3
MAX_CONVERSATION_TURNS=6

# Email Configuration (Optional - for sending welcome emails)
# If not configured, emails won't be sent but lead capture will still work
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=noreply@autostream.example.com

# WhatsApp Configuration (Optional - for WhatsApp deployment)
WHATSAPP_VERIFY_TOKEN=your_verify_token
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
